{
  "name": "dataops-copilot",
  "displayName": "DataOps Copilot",
  "description": "Manage data platform connections and run Snowflake SQL directly from VS Code.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:dataops.addConnection",
    "onCommand:dataops.removeConnection",
    "onCommand:dataops.switchConnection",
    "onCommand:dataops.runQuery",
    "onCommand:dataops.predictQueryCost",
    "onCommand:dataops.optimizeQuery",
    "onCommand:dataops.generateQuery",
    "onCommand:dataops.showDatabricksDetails",
    "onCommand:dataops.refreshDatabricksServices",
    "onCommand:dataops.previewTable",
    "onCommand:dataops.openHistoryItem",
    "onCommand:dataops.rerunHistoryItem",
    "onCommand:dataops.clearHistory",
    "onView:dataops.connectionsView",
    "onView:dataops.historyView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dataops.addConnection",
        "title": "DataOps: Add Connection",
        "category": "DataOps"
      },
      {
        "command": "dataops.removeConnection",
        "title": "DataOps: Remove Connection",
        "category": "DataOps"
      },
      {
        "command": "dataops.switchConnection",
        "title": "DataOps: Switch Active Connection",
        "category": "DataOps"
      },
      {
        "command": "dataops.runQuery",
        "title": "DataOps: Run Active SQL Query",
        "category": "DataOps"
      },
      {
        "command": "dataops.predictQueryCost",
        "title": "DataOps: Predict Query Cost",
        "category": "DataOps"
      },
      {
        "command": "dataops.optimizeQuery",
        "title": "DataOps: Optimize Query",
        "category": "DataOps"
      },
      {
        "command": "dataops.generateQuery",
        "title": "DataOps: Generate SQL",
        "category": "DataOps"
      },
      {
        "command": "dataops.showDatabricksDetails",
        "title": "DataOps: Show Databricks Details",
        "category": "DataOps"
      },
      {
        "command": "dataops.refreshDatabricksServices",
        "title": "DataOps: Refresh Databricks Services",
        "category": "DataOps"
      },
      {
        "command": "dataops.refreshConnections",
        "title": "DataOps: Refresh All Connections Data",
        "category": "DataOps",
        "icon": "$(refresh)"
      },
      {
        "command": "dataops.previewTable",
        "title": "DataOps: Preview Table",
        "category": "DataOps"
      },
      {
        "command": "dataops.openHistoryItem",
        "title": "Open in Editor",
        "category": "DataOps",
        "icon": "$(go-to-file)"
      },
      {
        "command": "dataops.rerunHistoryItem",
        "title": "Re-run Query",
        "category": "DataOps",
        "icon": "$(run)"
      },
      {
        "command": "dataops.clearHistory",
        "title": "DataOps: Clear Query History",
        "category": "DataOps",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dataops",
          "title": "DataOps Copilot",
          "icon": "resources/dataops.svg"
        }
      ]
    },
    "views": {
      "dataops": [
        {
          "id": "dataops.connectionsView",
          "name": "Connections"
        },
        {
          "id": "dataops.historyView",
          "name": "Query History"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "dataops.runQuery",
          "when": "resourceExtname == .sql",
          "group": "navigation"
        },
        {
          "command": "dataops.optimizeQuery",
          "when": "resourceExtname == .sql",
          "group": "navigation"
        },
        {
          "command": "dataops.predictQueryCost",
          "when": "resourceExtname == .sql",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "dataops.addConnection",
          "when": "view == dataops.connectionsView",
          "group": "navigation"
        },
        {
          "command": "dataops.removeConnection",
          "when": "view == dataops.connectionsView",
          "group": "navigation"
        },
        {
          "command": "dataops.refreshConnections",
          "when": "view == dataops.connectionsView",
          "group": "navigation"
        },
        {
          "command": "dataops.refreshDatabricksServices",
          "when": "view == dataops.connectionsView",
          "group": "navigation"
        },
        {
          "command": "dataops.clearHistory",
          "when": "view == dataops.historyView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dataops.refreshConnections",
          "when": "view == dataops.connectionsView && viewItem == dataops.connection",
          "group": "inline@1"
        },
        {
          "command": "dataops.removeConnection",
          "when": "view == dataops.connectionsView && viewItem == dataops.connection",
          "group": "inline@2"
        },
        {
          "command": "dataops.openHistoryItem",
          "when": "viewItem == dataops.historyItem",
          "group": "inline@1"
        },
        {
          "command": "dataops.rerunHistoryItem",
          "when": "viewItem == dataops.historyItem",
          "group": "inline@2"
        },
        {
          "command": "dataops.generateQuery",
          "when": "view == dataops.connectionsView && viewItem == dataops.table",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dataops.runQuery",
        "key": "ctrl+enter",
        "when": "editorTextFocus && resourceExtname == .sql"
      },
      {
        "command": "dataops.optimizeQuery",
        "key": "ctrl+alt+o",
        "when": "editorTextFocus && resourceExtname == .sql"
      },
      {
        "command": "dataops.predictQueryCost",
        "key": "ctrl+alt+p",
        "when": "editorTextFocus && resourceExtname == .sql"
      },
      {
        "command": "dataops.generateQuery",
        "key": "ctrl+alt+g",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "pretest": "npm run compile && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "."
  },
  "keywords": [
    "snowflake",
    "databricks",
    "dataops",
    "sql"
  ],
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.12.0",
    "axios": "^1.13.6",
    "dotenv": "^16.6.1",
    "snowflake-sdk": "^2.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3"
  }
}
